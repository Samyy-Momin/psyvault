rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    match /books/{bookId} {
      allow read: if true;
      allow create, update, delete: if isSignedIn();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isSignedIn();
    }

    match /quotes/{quoteId} {
      allow read: if true;
      allow create, update, delete: if isSignedIn();
    }
  }
}
